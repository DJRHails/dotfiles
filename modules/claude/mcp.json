{
  "mcpServers": {
    "playwriter": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "playwriter@0.0.105"
      ],
      "env": {
        "PLAYWRITER_AUTO_ENABLE": "1"
      }
    },
    "figma-dev-mode-mcp-server": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp"
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {}
    }
  }
}
