#!/usr/bin/env bash
# Upload local file(s) to cdn.hails.info (Cloudflare R2) and print their public URLs.
#
# Mirrors the kb project's r2_upload.py scheme: content-addressed keys
# `img/<sha256[:32]><ext>` in the `r2:cdn-hails-info` bucket, with an immutable
# cache header. Identical bytes collapse to one object (idempotent re-uploads).
#
# Routing (first that applies):
#   1. a local `rclone` with the `r2:` remote (maintainer hosts: trifle, or bonbon
#      once configured) — uploads directly.
#   2. a gantry worker ($GANTRY_BASE_URL + $GANTRY_API_KEY set) — POSTs the bytes to
#      gantry's /agent/attachments, which holds the R2 creds the sandboxed worker
#      lacks and returns the same content-addressed cdn.hails.info/img/<sha> URL.
#      Images only (png/jpeg/gif/webp); no rclone/ssh needed in the worker.
#   3. scp to `trifle` (the user's Mac) and run rclone there.
# So it works from a maintainer host, a gantry worker, or any tailnet host.
#
# Usage:
#   cdn-upload figure.png chart.svg ...     # prints one https://cdn.hails.info/... per file
set -euo pipefail

REMOTE="r2:cdn-hails-info"
BASE="https://cdn.hails.info"
CACHE_HEADER="Cache-Control: public, max-age=31536000, immutable"
emit_url() { printf '%s/%s\n' "$BASE" "$1"; }

if [ "$#" -eq 0 ]; then
  echo "usage: cdn-upload <file> [file...]" >&2
  exit 2
fi

have_local_r2() { command -v rclone >/dev/null 2>&1 && rclone listremotes 2>/dev/null | grep -qx "r2:"; }
have_gantry() { [ -n "${GANTRY_BASE_URL:-}" ] && [ -n "${GANTRY_API_KEY:-}" ]; }

content_key() { # <file> -> img/<sha256[:32]><.ext>
  local f="$1" sha ext
  sha="$(sha256sum "$f" | cut -c1-32)"
  ext=".${f##*.}"
  [ "$ext" = ".$f" ] && ext=".bin"
  printf 'img/%s%s' "$sha" "$(printf '%s' "$ext" | tr '[:upper:]' '[:lower:]')"
}

gantry_mime() { # <file> -> the image media-type gantry accepts, or empty
  case "$(printf '%s' "${1##*.}" | tr '[:upper:]' '[:lower:]')" in
  png) echo image/png ;;
  jpg | jpeg) echo image/jpeg ;;
  gif) echo image/gif ;;
  webp) echo image/webp ;;
  *) echo "" ;;
  esac
}

upload_local() { # <file> <key>
  rclone copyto "$1" "${REMOTE}/$2" --header-upload "$CACHE_HEADER"
}

upload_via_trifle() { # <file> <key>
  local f="$1" key="$2" tmp
  tmp="/tmp/cdn-upload.$$/$(basename "$key")"
  ssh trifle "mkdir -p /tmp/cdn-upload.$$"
  scp -q "$f" "trifle:$tmp"
  # Login shell so trifle's rclone (in /usr/local/bin) is on PATH.
  ssh trifle "bash -lc \"rclone copyto '$tmp' '${REMOTE}/$key' --header-upload '$CACHE_HEADER'\""
}

# Inside a gantry worker the R2 creds live in the control plane, not the sandbox:
# POST the raw bytes to /agent/attachments with the worker's thread-bound token.
# gantry stores them content-addressed in the same bucket and returns the public
# URL — so the worker never needs rclone, ssh, or any R2 credential.
upload_via_gantry() { # <file> -> prints the authoritative cdn url
  local f="$1" mime resp url
  mime="$(gantry_mime "$f")"
  if [ -z "$mime" ]; then
    echo "cdn-upload: in a gantry worker only images (png/jpeg/gif/webp) can be hosted via gantry attachments (got '$f'). Commit it and link the in-repo path instead." >&2
    return 1
  fi
  resp="$(curl -fsS -X POST \
    "${GANTRY_BASE_URL%/}/agent/attachments?media_type=${mime}&name=$(basename "$f")" \
    -H "Authorization: Bearer ${GANTRY_API_KEY}" \
    --data-binary @"$f")" || {
    echo "cdn-upload: gantry attachment upload failed for '$f'" >&2
    return 1
  }
  url="$(printf '%s' "$resp" | sed -n 's/.*"url"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')"
  [ -n "$url" ] || {
    echo "cdn-upload: no url in gantry response: $resp" >&2
    return 1
  }
  printf '%s\n' "$url"
}

for f in "$@"; do
  [ -f "$f" ] || {
    echo "not a file: $f" >&2
    exit 1
  }
  if have_local_r2; then
    key="$(content_key "$f")"
    upload_local "$f" "$key" >&2
    emit_url "$key"
  elif have_gantry; then
    upload_via_gantry "$f"
  else
    key="$(content_key "$f")"
    upload_via_trifle "$f" "$key" >&2
    emit_url "$key"
  fi
done
