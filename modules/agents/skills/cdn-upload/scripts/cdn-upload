#!/usr/bin/env bash
# Upload local file(s) to cdn.hails.info (Cloudflare R2) and print their public URLs.
#
# Mirrors the kb project's r2_upload.py scheme: content-addressed keys
# `img/<sha256[:32]><ext>` in the `r2:cdn-hails-info` bucket, with an immutable
# cache header. Identical bytes collapse to one object (idempotent re-uploads).
#
# Routing (first that applies):
#   1. a local `rclone` with the `r2:` remote (maintainer hosts: trifle, or bonbon
#      once configured) — uploads directly.
#   2. the `gantry` CLI with a token (a gantry worker, where $GANTRY_API_KEY is
#      injected) — `gantry attach` POSTs to gantry's /agent/attachments, which holds
#      the R2 creds the sandboxed worker lacks and returns the same content-addressed
#      cdn.hails.info/img/<sha> URL. Images only (png/jpeg/gif/webp). No rclone/ssh
#      or R2 credential needed in the worker.
#   3. scp to `trifle` (the user's Mac) and run rclone there.
# So it works from a maintainer host, a gantry worker, or any tailnet host.
#
# Usage:
#   cdn-upload figure.png chart.svg ...     # prints one https://cdn.hails.info/... per file
set -euo pipefail

REMOTE="r2:cdn-hails-info"
BASE="https://cdn.hails.info"
CACHE_HEADER="Cache-Control: public, max-age=31536000, immutable"
emit_url() { printf '%s/%s\n' "$BASE" "$1"; }

if [ "$#" -eq 0 ]; then
  echo "usage: cdn-upload <file> [file...]" >&2
  exit 2
fi

have_local_r2() { command -v rclone >/dev/null 2>&1 && rclone listremotes 2>/dev/null | grep -qx "r2:"; }
# A gantry worker has the `gantry` CLI on PATH and a thread-bound $GANTRY_API_KEY
# (also matches a maintainer host that has exported $GANTRY_TOKEN).
have_gantry() {
  command -v gantry >/dev/null 2>&1 && { [ -n "${GANTRY_API_KEY:-}" ] || [ -n "${GANTRY_TOKEN:-}" ]; }
}

content_key() { # <file> -> img/<sha256[:32]><.ext>
  local f="$1" sha ext
  sha="$(sha256sum "$f" | cut -c1-32)"
  ext=".${f##*.}"
  [ "$ext" = ".$f" ] && ext=".bin"
  printf 'img/%s%s' "$sha" "$(printf '%s' "$ext" | tr '[:upper:]' '[:lower:]')"
}

upload_local() { # <file> <key>
  rclone copyto "$1" "${REMOTE}/$2" --header-upload "$CACHE_HEADER"
}

upload_via_trifle() { # <file> <key>
  local f="$1" key="$2" tmp
  tmp="/tmp/cdn-upload.$$/$(basename "$key")"
  ssh trifle "mkdir -p /tmp/cdn-upload.$$"
  scp -q "$f" "trifle:$tmp"
  # Login shell so trifle's rclone (in /usr/local/bin) is on PATH.
  ssh trifle "bash -lc \"rclone copyto '$tmp' '${REMOTE}/$key' --header-upload '$CACHE_HEADER'\""
}

for f in "$@"; do
  [ -f "$f" ] || {
    echo "not a file: $f" >&2
    exit 1
  }
  if have_local_r2; then
    key="$(content_key "$f")"
    upload_local "$f" "$key" >&2
    emit_url "$key"
  elif have_gantry; then
    # Inside a gantry worker the R2 creds live in the control plane, not the
    # sandbox: the gantry CLI POSTs the bytes to /agent/attachments (worker token,
    # base+token resolved from the env gantry injects) and prints the same
    # content-addressed cdn.hails.info URL. Images only — gantry rejects the rest.
    gantry attach "$f"
  else
    key="$(content_key "$f")"
    upload_via_trifle "$f" "$key" >&2
    emit_url "$key"
  fi
done
